# ========================
# GitHub OAuth
# ========================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ========================
# Google AI (Gemini via ADK)
# ========================
GOOGLE_API_KEY=your_google_api_key

# ========================
# NextAuth.js
# ========================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_generate_with_openssl_rand_base64_32

# ========================
# Database (PostgreSQL)
# ========================
DATABASE_URL=postgresql+asyncpg://agentcommit:agentcommit@localhost:5432/agentcommit
POSTGRES_USER=agentcommit
POSTGRES_PASSWORD=agentcommit
POSTGRES_DB=agentcommit

# ========================
# Redis
# ========================
REDIS_URL=redis://localhost:6379/0

# ========================
# Backend
# ========================
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# ========================
# MCP Servers
# ========================
GITHUB_MCP_TOKEN=your_github_personal_access_token
